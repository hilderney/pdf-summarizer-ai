# Chave mestra para criptografar tokens OpenRouter e segredos TOTP (32 bytes em hex).
# Gere uma vez: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET_KEY=

# Opcional — token global OpenRouter (não substitui token por modelo na UI)
# OPENROUTER_API_KEY=

# Chave para assinar os JWTs de sessão (32 bytes em hex).
JWT_SECRET=

# Primeiro usuário ADM (criado apenas se o banco não tem usuários).
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=

# Tempos de sessão (segundos)
# JWT_ACCESS_TTL_SECONDS=900   # access token / countdown na UI (padrão 15 min)
# JWT_REFRESH_TTL_SECONDS=604800
# ELEVATION_TTL_SECONDS=900

# Persistência: sqlite (dev) ou mysql (produção Hostinger)
PERSISTENCE=sqlite
# DB_PATH=./data/app.db

# MySQL (quando PERSISTENCE=mysql)
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=pdf_summarizer

# PORT=4000
# HOST=127.0.0.1
# OUTPUT_DIR=./output
# LOGS_DIR=./logs

# Chave mestra para criptografar tokens OpenRouter salvos no SQLite (32 bytes em hex).
# Gere uma vez: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET_KEY=

# Opcional — token global OpenRouter (não substitui token por modelo na UI)
# OPENROUTER_API_KEY=

# DB_PATH=./data/app.db
# PORT=4000
# HOST=127.0.0.1
# OUTPUT_DIR=./output
# LOGS_DIR=./logs
